// Integration tests for LinearClient against real Linear API.
// Requires LINEAR_API_TOKEN in .env and the BTTEST project.
// Skipped when credentials are unavailable.

TestCase subclass: LinearClientIntegrationTest
  field: client = nil
  field: hasToken = false

  setUp =>
    DotEnv load: File cwd ++ "/.env"
    token := System getEnv: "LINEAR_API_TOKEN"
    found := token isNil not
    c := found ifTrue: [
      LinearClient new: #{#apiKey => token, #projectSlug => "c3c0717a652a"}
    ] ifFalse: [nil]
    (self withHasToken: found) withClient: c

  // --- Candidate fetch ---
  testFetchCandidateIssues =>
    self.hasToken ifFalse: [^self skip: "LINEAR_API_TOKEN not set"]
    result := self.client fetchCandidateIssues: #("Todo", "In Progress")
    issues := self assertOk: result
    self assert: issues size > 0

  testCandidateIssuesHaveRequiredFields =>
    self.hasToken ifFalse: [^self skip: "LINEAR_API_TOKEN not set"]
    issues := self assertOk: (self.client fetchCandidateIssues: #("Todo"))
    issues isEmpty ifTrue: [^self skip: "No Todo issues in BTTEST"]
    issue := issues at: 1
    self deny: (issue at: "id") isNil
    self deny: (issue at: "identifier") isNil
    self deny: (issue at: "title") isNil
    self deny: (issue at: "state") isNil

  testCandidateLabelsAreLowercase =>
    self.hasToken ifFalse: [^self skip: "LINEAR_API_TOKEN not set"]
    issues := self assertOk: (self.client fetchCandidateIssues: #("Todo"))
    issues
      do: [:issue |
        labels := issue at: "labels"
        labels do: [:label | self assert: label equals: label lowercase]
      ]

  testCandidateBlockersNormalized =>
    self.hasToken ifFalse: [^self skip: "LINEAR_API_TOKEN not set"]
    issues := self assertOk: (self.client fetchCandidateIssues: #("Todo"))
    // blockers should be a list (possibly empty) for every issue
    issues
      do: [:issue |
        blockers := issue at: "blocked_by"
        self assert: (blockers isKindOf: List)
      ]

  testEmptyStatesReturnsEmpty =>
    self.hasToken ifFalse: [^self skip: "LINEAR_API_TOKEN not set"]
    result := self.client fetchCandidateIssues: #()
    self assert: (self assertOk: result) equals: #()

  // --- State refresh ---
  testFetchIssueStatesByIds =>
    self.hasToken ifFalse: [^self skip: "LINEAR_API_TOKEN not set"]
    // First get some issue IDs
    issues := self assertOk: (self.client fetchCandidateIssues: #("Todo"))
    issues isEmpty ifTrue: [^self skip: "No Todo issues in BTTEST"]
    ids := issues collect: [:i | i at: "id"]
    // Now refresh their states
    result := self.client fetchIssueStatesByIds: ids
    refreshed := self assertOk: result
    // nodes query may return fewer results if some IDs are filtered
    refreshed do: [:r | self deny: (r at: "id") isNil]

  testFetchIssueStatesByIdsEmpty =>
    self.hasToken ifFalse: [^self skip: "LINEAR_API_TOKEN not set"]
    result := self.client fetchIssueStatesByIds: #()
    self assert: (self assertOk: result) equals: #()

  // --- Terminal fetch ---
  testFetchIssuesByStates =>
    self.hasToken ifFalse: [^self skip: "LINEAR_API_TOKEN not set"]
    result := self.client fetchIssuesByStates: #("Done", "Cancelled")
    self assertOk: result

  // May be empty if no terminal issues, but shouldn't error
  testFetchIssuesByStatesEmpty =>
    self.hasToken ifFalse: [^self skip: "LINEAR_API_TOKEN not set"]
    result := self.client fetchIssuesByStates: #()
    self assert: (self assertOk: result) equals: #()

  // --- Error handling ---
  testInvalidApiKeyReturnsError =>
    self.hasToken ifFalse: [^self skip: "No connectivity"]
    badClient := LinearClient new: #{
      #apiKey => "invalid_token",
      #projectSlug => "c3c0717a652a"
    }
    result := [
      badClient fetchCandidateIssues: #("Todo")
    ] on: Error do: [:e | Result error: e message]
    self assert: result isError
