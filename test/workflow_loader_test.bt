// Tests for WorkflowLoader

TestCase subclass: WorkflowLoaderTest
  state: tmpDir = "target/bt-test-tmp/workflow"

  setUp =>
    File mkdirAll: self.tmpDir
    self

  tearDown =>
    File deleteAll: self.tmpDir
    self

  testParsesWithFrontMatterAndBody =>
    nl := String fromCodePoint: 10
    content := "---"
      ++ nl
      ++ "tracker:"
      ++ nl
      ++ "  kind: linear"
      ++ nl
      ++ "---"
      ++ nl
      ++ "You are an agent."
    path := self.tmpDir ++ "/wf1.md"
    File writeAll: path contents: content
    result := WorkflowLoader load: path
    self assert: result isOk
    wf := result unwrap
    config := wf at: "config"
    self assert: ((config at: "tracker") at: "kind") equals: "linear"
    self assert: (wf at: "prompt_template") equals: "You are an agent."

  testParsesWithoutFrontMatter =>
    path := self.tmpDir ++ "/wf2.md"
    File writeAll: path contents: "Just a prompt body."
    result := WorkflowLoader load: path
    self assert: result isOk
    wf := result unwrap
    self assert: (wf at: "config") equals: #{}
    self assert: (wf at: "prompt_template") equals: "Just a prompt body."

  testMissingFileReturnsError =>
    result := WorkflowLoader load: self.tmpDir ++ "/nonexistent.md"
    self assert: result isError
    self assert: (result error at: "kind") equals: "missing_workflow_file"

  testNonMapFrontMatterReturnsError =>
    nl := String fromCodePoint: 10
    content := "---" ++ nl ++ "- just a list" ++ nl ++ "---" ++ nl ++ "body"
    path := self.tmpDir ++ "/wf3.md"
    File writeAll: path contents: content
    result := WorkflowLoader load: path
    self assert: result isError
    self assert: (result error at: "kind") equals: "workflow_front_matter_not_a_map"

  testEmptyFileReturnsEmptyConfig =>
    path := self.tmpDir ++ "/wf4.md"
    File writeAll: path contents: ""
    result := WorkflowLoader load: path
    self assert: result isOk
    wf := result unwrap
    self assert: (wf at: "config") equals: #{}

  testTrimsPromptBody =>
    nl := String fromCodePoint: 10
    content := "---"
      ++ nl
      ++ "tracker:"
      ++ nl
      ++ "  kind: linear"
      ++ nl
      ++ "---"
      ++ nl
      ++ nl
      ++ "  prompt body  "
      ++ nl
      ++ nl
    path := self.tmpDir ++ "/wf5.md"
    File writeAll: path contents: content
    result := WorkflowLoader load: path
    self assert: result isOk
    wf := result unwrap
    self assert: (wf at: "prompt_template") equals: "prompt body"

  testEmptyFrontMatterReturnsEmptyConfig =>
    nl := String fromCodePoint: 10
    content := "---" ++ nl ++ "---" ++ nl ++ "body text"
    path := self.tmpDir ++ "/wf6.md"
    File writeAll: path contents: content
    result := WorkflowLoader load: path
    self assert: result isOk
    wf := result unwrap
    self assert: (wf at: "config") equals: #{}
    self assert: (wf at: "prompt_template") equals: "body text"
