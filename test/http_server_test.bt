// Tests for HttpServer — dashboard and JSON API.
// Requires cowboy HTTP infrastructure (may not be available in all test contexts).

TestCase subclass: HttpServerTest
  field: srv = nil

  setUp =>
    server := [self tryStartServer] on: Error do: [:e | nil]
    self withSrv: server

  tryStartServer =>
    server := HttpServer start: 0 orchestrator: nil
    Timer sleep: 100
    server

  tearDown =>
    self.srv isNil ifFalse: [self.srv stop]
    self

  baseUrl => "http://localhost:" ++ self.srv actualPort displayString

  /// Helper: assert HTTP status on a Result<HTTPResponse>.
  assertStatus: expected :: Integer from: result :: Result =>
    resp := self assertOk: result
    self assert: (resp perform: #status) equals: expected

  /// Helper: get response body as string from a Result<HTTPResponse>.
  bodyFrom: result :: Result -> String =>
    resp := self assertOk: result
    resp perform: #body

  /// Helper: get response body as JSON from a Result<HTTPResponse>.
  jsonFrom: result :: Result -> Dictionary =>
    resp := self assertOk: result
    resp perform: #bodyAsJson

  testStartAndPort =>
    self.srv isNil ifTrue: [^self skip: "HTTPServer not available"]
    self assert: self.srv actualPort > 0
    self assert: self.srv isAlive

  testDashboard =>
    self.srv isNil ifTrue: [^self skip: "HTTPServer not available"]
    result := HTTPClient get: self baseUrl ++ "/"
    self assertStatus: 200 from: result
    self assert: ((self bodyFrom: result) includesSubstring: "Symphony")

  testApiState =>
    self.srv isNil ifTrue: [^self skip: "HTTPServer not available"]
    result := HTTPClient get: self baseUrl ++ "/api/v1/state"
    self assertStatus: 200 from: result

    json := self jsonFrom: result
    counts := json at: "counts"
    self assert: (counts at: "running") equals: 0

  testApiIssueNotFound =>
    self.srv isNil ifTrue: [^self skip: "HTTPServer not available"]
    result := HTTPClient get: self baseUrl ++ "/api/v1/NONEXISTENT-99"
    self assertStatus: 404 from: result

  testApiRefreshReturnsSnapshot =>
    self.srv isNil ifTrue: [^self skip: "HTTPServer not available"]
    result := HTTPClient post: self baseUrl ++ "/api/v1/refresh" body: ""
    self assertStatus: 200 from: result

    json := self jsonFrom: result
    counts := json at: "counts"
    self assert: (counts at: "running") equals: 0

  testNotFound =>
    self.srv isNil ifTrue: [^self skip: "HTTPServer not available"]
    result := HTTPClient get: self baseUrl ++ "/nonexistent"
    self assertStatus: 404 from: result
