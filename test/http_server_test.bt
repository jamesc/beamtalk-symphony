// Tests for HttpServer — dashboard and JSON API.
// Requires cowboy HTTP infrastructure (may not be available in all test contexts).

TestCase subclass: HttpServerTest
  state: srv = nil

  setUp =>
    self.srv := [self tryStartServer] on: Error do: [:e | nil]
    self

  tryStartServer =>
    server := HttpServer start: 0 orchestrator: nil
    Timer sleep: 100
    server

  tearDown =>
    self.srv isNil ifFalse: [self.srv stop]
    self

  baseUrl =>
    "http://localhost:" ++ self.srv actualPort displayString

  testStartAndPort =>
    self.srv isNil ifTrue: [^self skip: "HTTPServer not available"]
    self assert: self.srv actualPort > 0
    self assert: self.srv isAlive

  testDashboard =>
    self.srv isNil ifTrue: [^self skip: "HTTPServer not available"]
    resp := (HTTPClient get: self baseUrl ++ "/") unwrap
    @expect type
    self assert: resp status equals: 200
    @expect type
    self assert: (resp body includesSubstring: "Symphony")

  testApiState =>
    self.srv isNil ifTrue: [^self skip: "HTTPServer not available"]
    resp := (HTTPClient get: self baseUrl ++ "/api/v1/state") unwrap
    @expect type
    self assert: resp status equals: 200
    @expect type
    json := resp bodyAsJson
    counts := json at: "counts"
    self assert: (counts at: "running") equals: 0

  testApiIssueNotFound =>
    self.srv isNil ifTrue: [^self skip: "HTTPServer not available"]
    resp := (HTTPClient get: self baseUrl ++ "/api/v1/NONEXISTENT-99") unwrap
    @expect type
    self assert: resp status equals: 404

  testApiRefresh =>
    self.srv isNil ifTrue: [^self skip: "HTTPServer not available"]
    resp := (HTTPClient post: self baseUrl ++ "/api/v1/refresh" body: "") unwrap
    @expect type
    self assert: resp status equals: 202
    @expect type
    json := resp bodyAsJson
    self assert: (json at: "queued") equals: true

  testNotFound =>
    self.srv isNil ifTrue: [^self skip: "HTTPServer not available"]
    resp := (HTTPClient get: self baseUrl ++ "/nonexistent") unwrap
    @expect type
    self assert: resp status equals: 404
