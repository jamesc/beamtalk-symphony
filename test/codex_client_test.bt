// Tests for CodexClient — unit tests for protocol helpers and token extraction.
// Integration tests require a real codex app-server.

TestCase subclass: CodexClientTest

  testStartCreatesActor =>
    config := ResolvedConfig new: #{
      #codexCommand => "echo hello",
      #codexReadTimeoutMs => 1000
    }
    client := CodexClient
      start: "/tmp"
      config: config
      onEvent: nil
    self assert: client isAlive
    self assert: client stop equals: #ok

  // --- Token extraction ---
  testExtractUsageFromTotalTokenUsage =>
    msg := #{
      "params" => #{
        "total_token_usage" => #{
          "input_tokens" => 100,
          "output_tokens" => 50,
          "total_tokens" => 150
        }
      }
    }
    usage := CodexClient extractUsage: msg
    self deny: usage isNil
    self assert: (usage at: "input") equals: 100
    self assert: (usage at: "output") equals: 50
    self assert: (usage at: "total") equals: 150

  testExtractUsageFromUsageField =>
    msg := #{
      "params" => #{
        "usage" => #{
          "inputTokens" => 200,
          "outputTokens" => 80,
          "totalTokens" => 280
        }
      }
    }
    usage := CodexClient extractUsage: msg
    self deny: usage isNil
    self assert: (usage at: "input") equals: 200
    self assert: (usage at: "output") equals: 80

  testExtractUsageReturnsNilWhenMissing =>
    msg := #{"params" => #{}}
    self assert: (CodexClient extractUsage: msg) equals: nil

  testExtractRateLimits =>
    msg := #{"params" => #{"rate_limits" => #{"requests" => 100}}}
    limits := CodexClient extractRateLimits: msg
    self deny: limits isNil
    self assert: (limits at: "requests") equals: 100

  testExtractRateLimitsNilWhenMissing =>
    msg := #{"params" => #{}}
    self assert: (CodexClient extractRateLimits: msg) equals: nil
