// Tests for Logger (wraps Erlang logger)

TestCase subclass: LoggerTest

  testInfoReturnsOk =>
    result := Logger info: "service started"
    self assert: result equals: #ok

  testWarnReturnsOk =>
    result := Logger warn: "something unusual"
    self assert: result equals: #ok

  testErrorReturnsOk =>
    result := Logger error: "failed hard"
    self assert: result equals: #ok

  testDebugReturnsOk =>
    result := Logger debug: "trace info"
    self assert: result equals: #ok

  testInfoWithContext =>
    result := Logger info: "dispatched" context: #{"issue_id" => "abc"}
    self assert: result equals: #ok

  testIssueContext =>
    issue := #{"id" => "abc", "identifier" => "BT-42"}
    ctx := Logger issueContext: issue
    self assert: (ctx at: "issue_id") equals: "abc"
    self assert: (ctx at: "issue_identifier") equals: "BT-42"

  testSessionContext =>
    ctx := Logger sessionContext: "thread1-turn1"
    self assert: (ctx at: "session_id") equals: "thread1-turn1"

  testIssueAndSessionContext =>
    issue := #{"id" => "abc", "identifier" => "BT-42"}
    ctx := Logger issueContext: issue session: "s1"
    self assert: (ctx at: "issue_id") equals: "abc"
    self assert: (ctx at: "issue_identifier") equals: "BT-42"
    self assert: (ctx at: "session_id") equals: "s1"
