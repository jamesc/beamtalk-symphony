// Integration tests for CodexClient against real codex app-server.
// Requires codex to be installed. Skipped if not available.

TestCase subclass: CodexClientIntegrationTest
  state: hasCodex = false
  state: tmpDir = "target/bt-test-tmp/codex-integration"

  setUp =>
    self.hasCodex := [self checkCodexInstalled] on: Error do: [:e | false]
    File mkdirAll: self.tmpDir
    self

  checkCodexInstalled =>
    result := Erlang os find_executable: "codex"
    result == false ifTrue: [^false]
    true

  tearDown =>
    File deleteAll: self.tmpDir
    self

  testLaunchAndHandshake =>
    self.hasCodex ifFalse: [^self skip: "codex not installed"]
    config := Config fromMap: #{
      "codex" => #{"command" => "codex app-server", "read_timeout_ms" => 30000}
    }
    client := CodexClient start: self.tmpDir config: config onEvent: nil
    sessionResult := [client startSession] on: Error do: [:e |
      client stopProcess
      client stop
      ^self skip: "codex handshake error"
    ]
    sessionResult isError ifTrue: [
      client stopProcess
      client stop
      ^self skip: "codex session error"
    ]
    data := sessionResult unwrap
    self deny: (data at: "threadId") isNil
    client stopProcess
    self assert: client stop equals: #ok

  testStartTurn =>
    self.hasCodex ifFalse: [^self skip: "codex not installed"]
    config := Config fromMap: #{
      "codex" => #{"command" => "codex app-server", "read_timeout_ms" => 30000, "turn_timeout_ms" => 60000}
    }
    client := CodexClient start: self.tmpDir config: config onEvent: nil
    sessionResult := [client startSession] on: Error do: [:e |
      client stopProcess
      client stop
      ^self skip: "codex session error"
    ]
    sessionResult isError ifTrue: [
      client stopProcess
      client stop
      ^self skip: "codex session error"
    ]
    threadId := (sessionResult unwrap) at: "threadId"
    turnResult := [client startTurn: threadId prompt: "Say hello and nothing else." title: "test"]
      on: Error do: [:e |
        client stopProcess
        client stop
        ^self skip: "codex turn error"
      ]
    turnResult isError ifTrue: [
      client stopProcess
      client stop
      ^self skip: "codex turn error"
    ]
    self deny: ((turnResult unwrap) at: "turnId") isNil
    streamResult := client streamTurn: 60000
    self assert: streamResult isOk
    client stopProcess
    self assert: client stop equals: #ok

  testLaunchFailsWithBadCommand =>
    self.hasCodex ifFalse: [^self skip: "codex not installed"]
    config := Config fromMap: #{
      "codex" => #{"command" => "nonexistent_command_xyz", "read_timeout_ms" => 2000}
    }
    client := CodexClient start: self.tmpDir config: config onEvent: nil
    result := [client startSession] on: Error do: [:e | Result error: e message]
    self assert: result isError
    client stopProcess
    self assert: client stop equals: #ok
