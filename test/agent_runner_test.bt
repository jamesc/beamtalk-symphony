// Tests for AgentRunner — unit tests for prompt rendering.
// Full lifecycle tests require a real codex app-server.
// Note: buildPrompt/buildFirstTurnPrompt/buildContinuationPrompt were
// inlined into runTurnLoop (BT-1420 workaround). We test via PromptRenderer.

TestCase subclass: AgentRunnerTest

  testFirstTurnPromptRendering =>
    issue := #{"identifier" => "BT-1", "title" => "Fix bug", "id" => "abc"}
    lb := "\{"
    rb := "}"
    template := lb
      ++ lb
      ++ " issue.identifier "
      ++ rb
      ++ rb
      ++ ": "
      ++ lb
      ++ lb
      ++ " issue.title "
      ++ rb
      ++ rb
    result := PromptRenderer
      render: template
      issue: issue
      attempt: nil
    self assert: result isOk
    self assert: result unwrap equals: "BT-1: Fix bug"

  testContinuationPromptFormat =>
    turnNumber := 3
    prompt := "Continue working on this issue. This is turn "
      ++ turnNumber displayString
      ++ "."
    self assert: (prompt includesSubstring: "turn 3")
    self assert: (prompt includesSubstring: "Continue")

  testFirstTurnPromptWithAttempt =>
    issue := #{"identifier" => "X-1", "title" => "Task", "id" => "x"}
    result := PromptRenderer
      render: "Work on it"
      issue: issue
      attempt: 2
    self assert: result isOk
    self assert: result unwrap equals: "Work on it"
