// Tests for RetryAttempt (Value subclass)

TestCase subclass: RetryAttemptTest

  testNewWithDefaults =>
    entry := RetryAttempt new
    self assert: entry issueId equals: ""
    self assert: entry identifier equals: ""
    self assert: entry attempt equals: 1
    self assert: entry dueAtMs equals: 0
    self assert: entry timerRef equals: nil
    self assert: entry error equals: nil

  testNewWithMap =>
    entry := RetryAttempt
      new: #{
        #issueId => "abc123",
        #identifier => "BT-456",
        #attempt => 3,
        #dueAtMs => 99999,
        #error => "turn failed"
      }
    self assert: entry issueId equals: "abc123"
    self assert: entry identifier equals: "BT-456"
    self assert: entry attempt equals: 3
    self assert: entry dueAtMs equals: 99999
    self assert: entry error equals: "turn failed"

  testWithTimerRef =>
    entry := RetryAttempt new
    updated := entry withTimerRef: #some_ref
    self assert: updated timerRef equals: #some_ref

  testBackoffMs =>
    self assert: (RetryAttempt backoffMs: 1 maxMs: 300000) equals: 10000
    self assert: (RetryAttempt backoffMs: 2 maxMs: 300000) equals: 20000
    self assert: (RetryAttempt backoffMs: 3 maxMs: 300000) equals: 40000
    self assert: (RetryAttempt backoffMs: 4 maxMs: 300000) equals: 80000
    self assert: (RetryAttempt backoffMs: 5 maxMs: 300000) equals: 160000
    // Capped at max
    self assert: (RetryAttempt backoffMs: 6 maxMs: 300000) equals: 300000
    self assert: (RetryAttempt backoffMs: 7 maxMs: 300000) equals: 300000

  testBackoffMsWithSmallCap =>
    self assert: (RetryAttempt backoffMs: 1 maxMs: 50000) equals: 10000
    self assert: (RetryAttempt backoffMs: 3 maxMs: 50000) equals: 40000
    self assert: (RetryAttempt backoffMs: 4 maxMs: 50000) equals: 50000

  testContinuationDelayMs =>
    self assert: RetryAttempt continuationDelayMs equals: 1000
