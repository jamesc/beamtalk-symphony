// Tests for RunningEntry (Value subclass, composes SessionInfo + TokenUsage)

TestCase subclass: RunningEntryTest

  testDefaults =>
    entry := RunningEntry new
    self assert: entry identifier equals: ""
    self assert: entry issue equals: nil
    self assert: entry session equals: nil
    self assert: entry tokens equals: nil
    self assert: entry retryAttempt equals: nil

  testForIssueFactory =>
    issue := #{"id" => "abc", "title" => "Test"}
    entry := RunningEntry
      forIssue: issue
      identifier: "BT-123"
      startedAt: 1000
    self assert: entry identifier equals: "BT-123"
    self assert: (entry issue at: "id") equals: "abc"
    self assert: entry startedAt equals: 1000
    // Session and tokens are initialized
    self assert: entry session turnCount equals: 0
    self assert: entry tokens input equals: 0

  testUpdateSession =>
    entry := RunningEntry
      forIssue: #{"id" => "x"}
      identifier: "BT-1"
      startedAt: 0
    newSession := (entry session withSessionId: "s1") withThreadId: "t1"
    updated := entry withSession: newSession
    self assert: updated session sessionId equals: "s1"
    self assert: updated session threadId equals: "t1"

  testUpdateTokens =>
    entry := RunningEntry
      forIssue: #{"id" => "x"}
      identifier: "BT-1"
      startedAt: 0
    newTokens := entry tokens
      applyAbsolute: 100
      output: 50
      total: 150
    updated := entry withTokens: newTokens
    self assert: updated tokens input equals: 100
    self assert: updated tokens output equals: 50

  testIncrementTurnCount =>
    entry := RunningEntry
      forIssue: #{"id" => "x"}
      identifier: "BT-1"
      startedAt: 0
    updated := entry withSession: entry session incrementTurnCount
    self assert: updated session turnCount equals: 1

  testImmutability =>
    entry := RunningEntry
      forIssue: #{"id" => "x"}
      identifier: "BT-1"
      startedAt: 0
    entry withIdentifier: "changed"
    // Original unchanged
    self assert: entry identifier equals: "BT-1"
