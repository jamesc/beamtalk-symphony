/// TemplateError — typed error for prompt template rendering failures.
typed Value subclass: TemplateError
  field: kind :: String = "render_error"
  field: detail :: String = ""

  class renderError: detail :: String -> TemplateError =>
    self new: #{#detail => detail}

  displayString -> String => "TemplateError: " ++ self.detail displayString
