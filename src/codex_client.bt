/// CodexClient — manages a codex app-server subprocess over stdio.
/// Handles JSON-RPC protocol, session startup handshake,
/// request/response matching, and turn streaming.
///
/// Uses helper methods (launch, sendRequest:params:, etc.) for protocol steps.
Actor subclass: CodexClient
  state: proc = nil
  state: nextId :: Integer = 1
  state: workspacePath :: String
  state: config :: Config
  state: onEvent :: Block

  /// Spawns a new CodexClient actor bound to the given workspace directory.
  class start: workspacePath :: String config: config :: Config onEvent: callback :: Block -> CodexClient =>
    client := self spawnWith: #{
      #workspacePath => workspacePath,
      #config => config,
      #onEvent => callback
    }
    client

  // --- Token and rate-limit extraction ---

  /// Extracts token usage counters from a codex event message, or nil.
  class extractUsage: msg :: Dictionary -> Dictionary =>
    // Look for token usage in common payload shapes
    params := msg at: "params" ifAbsent: [#{}]
    // Try tokenUsage.total (codex format), then total_token_usage, then usage
    tokenUsage := params at: "tokenUsage" ifAbsent: [nil]
    usage := (tokenUsage isNil not and: [tokenUsage isKindOf: Dictionary])
      ifTrue: [tokenUsage at: "total" ifAbsent: [nil]]
      ifFalse: [nil]
    usage := usage isNil ifTrue: [
      params at: "total_token_usage" ifAbsent: [
        params at: "usage" ifAbsent: [nil]
      ]
    ] ifFalse: [usage]
    usage isNil ifTrue: [^nil]
    (usage isKindOf: Dictionary) ifFalse: [^nil]
    #{
      "input" => (usage at: "input_tokens" ifAbsent: [
        usage at: "inputTokens" ifAbsent: [0]
      ]),
      "output" => (usage at: "output_tokens" ifAbsent: [
        usage at: "outputTokens" ifAbsent: [0]
      ]),
      "total" => (usage at: "total_tokens" ifAbsent: [
        usage at: "totalTokens" ifAbsent: [0]
      ])
    }

  /// Extracts rate limit info from a codex event message, or nil.
  class extractRateLimits: msg :: Dictionary =>
    params := msg at: "params" ifAbsent: [#{}]
    params at: "rate_limits" ifAbsent: [params at: "rateLimits" ifAbsent: [nil]]

  // --- Subprocess lifecycle ---
  terminate: _reason =>
    self stopProcess

  stopProcess =>
    Logger debug: "codex process stopping"
    self.proc isNil
      ifFalse: [
        self.proc close
        self.proc stop
        self.proc := nil
      ]

  // --- Subprocess launch ---

  /// Opens the codex subprocess and sets self.proc.
  launch -> Result =>
    procResult := [
      Subprocess
        open: "/bin/bash"
        args: #("-lc", self.config codexCommand)
        dir: self.workspacePath
    ]
      on: Error
      do: [:e |
        Logger error: "codex launch failed" metadata: #{"error" => e message}
        ^Result error: #{"kind" => "codex_not_found", "detail" => e message}
      ]
    procResult isError
      ifTrue: [
        Logger error: "codex launch error" metadata: #{
          "error" => procResult error displayString
        }
        ^Result error: #{
          "kind" => "codex_not_found",
          "detail" => procResult error displayString
        }
      ]
    self.proc := procResult unwrap
    Logger info: "codex process launched"
    Result ok: nil

  // --- JSON-RPC helpers ---

  /// Writes a JSON-RPC message to the subprocess.
  sendJson: msg :: Dictionary =>
    line := Json generate: msg
    self.proc writeLine: line

  /// Allocates a request ID, sends the request, and returns the ID.
  sendRequest: method :: String params: params :: Dictionary -> Integer =>
    id := self.nextId
    self.nextId := self.nextId + 1
    msg := #{"id" => id, "method" => method, "params" => params}
    Logger debug: "codex >> " ++ method ++ " (id=" ++ id displayString ++ ")"
    self sendJson: msg
    id

  /// Sends a notification (no id, no response expected).
  sendNotification: method :: String params: params :: Dictionary =>
    msg := #{"method" => method, "params" => params}
    Logger debug: "codex >> " ++ method ++ " (notification)"
    self sendJson: msg

  // --- Response reading (no state mutation, self-recursion is safe) ---
  readResponse: expectedId :: Integer timeout: timeoutMs :: Integer -> Result =>
    deadline := (DateTime now asTimestamp * 1000) + timeoutMs
    self readUntilResponse: expectedId deadline: deadline

  readUntilResponse: expectedId :: Integer deadline: deadline :: Integer -> Result =>
    remaining := deadline - (DateTime now asTimestamp * 1000)
    remaining <= 0
      ifTrue: [
        Logger warn: "codex response timeout" metadata: #{
          "id" => expectedId displayString
        }
        ^Result error: #{"kind" => "response_timeout", "id" => expectedId}
      ]
    readTimeout := remaining > 1000 ifTrue: [1000] ifFalse: [remaining]

    line := self.proc readLine: readTimeout
    line isNil
      ifTrue: [
        exitCode := self.proc exitCode
        exitCode isNil
          ifFalse: [
            Logger warn: "codex process exited" metadata: #{
              "exit_code" => exitCode displayString
            }
            ^Result error: #{"kind" => "port_exit", "exit_code" => exitCode}
          ]
        ^self readUntilResponse: expectedId deadline: deadline
      ]
    Logger debug: "codex << " ++ line

    parsed := [Json parse: line] on: Error do: [:e | nil]
    parsed isNil
      ifTrue: [
        Logger debug: "codex non-JSON line, skipping"
        ^self readUntilResponse: expectedId deadline: deadline
      ]
    parsedMsg := parsed unwrap
    msgId := parsedMsg at: "id" ifAbsent: [nil]
    msgId == expectedId ifTrue: [^Result ok: parsedMsg]
    // Notification or different response — emit as event
    method := parsedMsg at: "method" ifAbsent: ["?"]
    Logger debug: "codex event: " ++ method displayString
    self emitEvent: parsedMsg
    self readUntilResponse: expectedId deadline: deadline

  // --- Session startup handshake ---

  /// Launches the subprocess and performs the initialize/thread-start handshake.
  startSession -> Result =>
    Logger info: "codex session starting" metadata: #{
      "workspace" => self.workspacePath,
      "command" => self.config codexCommand
    }

    launchResult := self launch
    launchResult isError ifTrue: [^launchResult]

    readTimeout := self.config codexReadTimeoutMs

    // Step 1: initialize request
    initId := self sendRequest: "initialize" params: #{
      "clientInfo" => #{"name" => "symphony", "version" => "1.0"},
      "capabilities" => #{}
    }
    initResp := self readResponse: initId timeout: readTimeout
    initResp isError
      ifTrue: [
        Logger error: "codex initialize failed" metadata: #{
          "error" => initResp error displayString
        }
        self stopProcess
        ^Result
          error: #{
            "kind" => "startup_failed",
            "step" => "initialize",
            "detail" => initResp error
          }
      ]
    Logger info: "codex initialized"

    // Step 2: initialized notification
    self sendNotification: "initialized" params: #{}

    // Step 3: thread/start request
    threadReqId := self sendRequest: "thread/start" params: #{"cwd" => self.workspacePath}
    threadResp := self readResponse: threadReqId timeout: readTimeout
    threadResp isError
      ifTrue: [
        Logger error: "codex thread/start failed" metadata: #{
          "error" => threadResp error displayString
        }
        self stopProcess
        ^Result
          error: #{
            "kind" => "startup_failed",
            "step" => "thread/start",
            "detail" => threadResp error
          }
      ]

    // Extract thread ID from response
    threadData := threadResp unwrap
    @expect type  // unwrap → Object, needs parameterized Result (BT-1547)
    threadResult := threadData at: "result" ifAbsent: [#{}]
    thread := threadResult at: "thread" ifAbsent: [#{}]
    tid := thread at: "id" ifAbsent: [nil]

    Logger info: "codex session ready" metadata: #{
      "threadId" => tid displayString
    }
    Result ok: #{"threadId" => tid}

  // --- Turn management ---

  /// Sends a turn/start request with the given prompt and waits for acknowledgement.
  startTurn: threadId :: String prompt: prompt :: String title: title :: String -> Result =>
    Logger info: "codex turn starting" metadata: #{
      "title" => title,
      "prompt_length" => prompt length displayString
    }
    readTimeout := self.config codexReadTimeoutMs
    turnId := self sendRequest: "turn/start" params: #{
      "threadId" => threadId,
      "input" => #(#{"type" => "text", "text" => prompt}),
      "cwd" => self.workspacePath,
      "title" => title,
      "sandboxPolicy" => #{"type" => "dangerFullAccess"}
    }
    turnResp := self readResponse: turnId timeout: readTimeout
    turnResp isError
      ifTrue: [
        Logger error: "codex turn/start failed" metadata: #{
          "error" => turnResp error displayString
        }
        ^turnResp
      ]

    turnData := turnResp unwrap
    @expect type  // unwrap → Object, needs parameterized Result (BT-1547)
    turnResult := turnData at: "result" ifAbsent: [#{}]
    turn := turnResult at: "turn" ifAbsent: [#{}]
    tuid := turn at: "id" ifAbsent: [nil]

    Logger info: "codex turn started" metadata: #{
      "turnId" => tuid displayString
    }
    Result ok: #{"turnId" => tuid}

  /// Streams events until the turn completes, fails, or times out.
  streamTurn: turnTimeoutMs :: Integer -> Result =>
    deadline := (DateTime now asTimestamp * 1000) + turnTimeoutMs
    self streamUntilDone: deadline

  streamUntilDone: deadline :: Integer -> Result =>
    remaining := deadline - (DateTime now asTimestamp * 1000)
    remaining <= 0
      ifTrue: [
        Logger warn: "codex turn timed out"
        ^Result error: #{"kind" => "turn_timeout"}
      ]
    readTimeout := remaining > 1000 ifTrue: [1000] ifFalse: [remaining]

    line := self.proc readLine: readTimeout
    line isNil
      ifTrue: [
        exitCode := self.proc exitCode
        exitCode isNil
          ifFalse: [
            Logger warn: "codex process exited during stream" metadata: #{
              "exit_code" => exitCode displayString
            }
            ^Result error: #{"kind" => "port_exit", "exit_code" => exitCode}
          ]
        ^self streamUntilDone: deadline
      ]
    Logger debug: "codex << " ++ line

    parsed := [Json parse: line] on: Error do: [:e | nil]
    parsed isNil ifTrue: [^self streamUntilDone: deadline]
    msg := parsed unwrap
    self handleStreamMessage: msg deadline: deadline

  handleStreamMessage: msg :: Dictionary deadline: deadline :: Integer -> Result =>
    method := msg at: "method" ifAbsent: [nil]

    // Check for turn completion
    method == "turn/completed"
      ifTrue: [
        Logger info: "codex turn completed"
        self emitEvent: msg
        ^Result ok: #{"status" => "completed", "message" => msg}
      ]
    method == "turn/failed"
      ifTrue: [
        Logger error: "codex turn failed" metadata: #{
          "method" => method displayString
        }
        self emitEvent: msg
        ^Result error: #{"kind" => "turn_failed", "message" => msg}
      ]
    method == "turn/cancelled"
      ifTrue: [
        Logger warn: "codex turn cancelled"
        self emitEvent: msg
        ^Result error: #{"kind" => "turn_cancelled", "message" => msg}
      ]

    // Handle approval requests — auto-approve all types
    id := msg at: "id" ifAbsent: [nil]
    ((method == "item/approval/request")
      or: [
        (method == "item/commandExecution/requestApproval") or: [
          method == "item/fileChange/requestApproval"
        ]
      ])
      ifTrue: [
        Logger debug: "codex auto-approving: " ++ method
        self sendJson: #{"id" => id, "result" => #{"approved" => true}}
        self emitEvent: msg
        ^self streamUntilDone: deadline
      ]

    // Handle user input required — hard failure
    (method == "item/tool/requestUserInput")
      ifTrue: [
        Logger warn: "codex requires user input, failing turn"
        self emitEvent: msg
        ^Result error: #{"kind" => "turn_input_required", "message" => msg}
      ]

    // Handle unsupported tool calls
    (method == "item/tool/call")
      ifTrue: [
        Logger warn: "codex unsupported tool call" metadata: #{
          "method" => method displayString
        }
        self
          sendJson: #{
            "id" => id,
            "result" => #{
              "success" => false,
              "error" => "unsupported_tool_call"
            }
          }
        self emitEvent: msg
        ^self streamUntilDone: deadline
      ]

    // Any other message — log method and continue
    method isNil ifFalse: [Logger debug: "codex event: " ++ method]
    self emitEvent: msg
    self streamUntilDone: deadline

  // --- Event emission ---
  emitEvent: msg :: Dictionary =>
    self.onEvent isNil
      ifFalse: [
        // Enrich with extracted usage and rate limits
        event := #{
          "raw" => msg,
          "method" => (msg at: "method" ifAbsent: [nil]),
          "usage" => (CodexClient extractUsage: msg),
          "rateLimits" => (CodexClient extractRateLimits: msg),
          "timestamp" => (DateTime now asTimestamp * 1000)
        }
        self.onEvent value: event
      ]
