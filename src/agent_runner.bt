// AgentRunner — wraps the full worker attempt lifecycle:
// workspace creation → prompt rendering → codex session → multi-turn loop
// → hook execution → event forwarding to orchestrator.

Actor subclass: AgentRunner
  state: issue = nil
  state: attempt = nil
  state: config = nil
  state: workspaceManager = nil
  state: linearClient = nil
  state: promptTemplate = nil
  state: onEvent = nil
  state: codexClient = nil
  state: threadId = nil
  state: turnNumber = 0

  class run: issue attempt: attempt config: config workspaceManager: wm linearClient: lc promptTemplate: pt onEvent: callback =>
    runner := self
      spawnWith: #{
        #issue => issue,
        #attempt => attempt,
        #config => config,
        #workspaceManager => wm,
        #linearClient => lc,
        #promptTemplate => pt,
        #onEvent => callback
      }
    runner start!
    runner

  // --- Main lifecycle ---
  start =>
    result := self doRun
    result isError
      ifTrue: [
        Logger
          error: "agent run failed"
          context: #{
            "issue_identifier" => (self.issue at: "identifier" ifAbsent: [""]),
            "error" => result error displayString
          }
        self error: result error displayString
      ]

  doRun =>
    identifier := self.issue at: "identifier" ifAbsent: [""]

    // Step 1: Create/reuse workspace
    wsResult := self.workspaceManager createForIssue: identifier
    wsResult isError ifTrue: [^wsResult]
    wsPath := wsResult unwrap at: "path"

    // Step 2: Run before_run hook
    hookResult := self.workspaceManager runBeforeRun: wsPath
    hookResult isError ifTrue: [^hookResult]

    // Step 3: Start codex session
    self.codexClient := CodexClient
      start: wsPath
      config: self.config
      onEvent: self.onEvent
    sessionResult := self.codexClient startSession
    sessionResult isError
      ifTrue: [
        self runAfterRunHook: wsPath
        self.codexClient stopProcess
        self.codexClient stop
        ^sessionResult
      ]

    sessionData := sessionResult unwrap
    self.threadId := sessionData at: "threadId"

    // Step 4: Multi-turn loop
    self.turnNumber := 1
    maxTurns := self.config maxTurns
    turnLoopResult := self runTurnLoop: wsPath maxTurns: maxTurns

    // Step 5: Cleanup
    self.codexClient stopProcess
    self.codexClient stop
    self runAfterRunHook: wsPath

    turnLoopResult

  // --- Turn loop ---
  runTurnLoop: wsPath maxTurns: maxTurns =>
    // Build prompt for this turn
    prompt := self buildPrompt
    prompt isError ifTrue: [^prompt]
    promptText := prompt unwrap

    // Start the turn
    title := (self.issue at: "identifier" ifAbsent: [""])
      ++ ": "
      ++ (self.issue at: "title" ifAbsent: [""])
    turnResult := self.codexClient
      startTurn: self.threadId
      prompt: promptText
      title: title
    turnResult isError ifTrue: [^turnResult]

    // Stream events until turn completes
    turnTimeoutMs := self.config codexTurnTimeoutMs
    streamResult := self.codexClient streamTurn: turnTimeoutMs
    streamResult isError ifTrue: [^streamResult]

    // Turn completed successfully — check if we should continue
    self shouldContinue: wsPath maxTurns: maxTurns

  shouldContinue: wsPath maxTurns: maxTurns =>
    // Check if max turns reached
    self.turnNumber >= maxTurns ifTrue: [
      ^Result ok: #{"status" => "max_turns_reached"}
    ]

    // Re-check issue state via tracker
    refreshResult := self.linearClient fetchIssueStatesByIds: #(self.issue at: "id")
    refreshResult isError ifTrue: [^refreshResult]

    refreshed := refreshResult unwrap
    refreshed isEmpty ifTrue: [^Result ok: #{"status" => "issue_not_found"}]

    currentState := (refreshed at: 1) at: "state" ifAbsent: [nil]
    activeStates := self.config trackerActiveStates
    isActive := activeStates anySatisfy: [:s |
      s lowercase == currentState lowercase
    ]
    isActive ifFalse: [
      ^Result ok: #{
        "status" => "issue_no_longer_active",
        "state" => currentState
      }
    ]

    // Continue with next turn
    self.turnNumber := self.turnNumber + 1
    self runTurnLoop: wsPath maxTurns: maxTurns

  // --- Prompt building ---
  buildPrompt =>
    self.turnNumber == 1 ifTrue: [
      self buildFirstTurnPrompt
    ] ifFalse: [self buildContinuationPrompt]

  buildFirstTurnPrompt =>
    PromptRenderer
      render: self.promptTemplate
      issue: self.issue
      attempt: self.attempt

  buildContinuationPrompt =>
    // Continuation turns get guidance, not the full prompt
    guidance := "Continue working on this issue. This is turn "
      ++ self.turnNumber displayString
      ++ "."
    Result ok: guidance

  // --- Helpers ---
  runAfterRunHook: wsPath =>
    // after_run failures are logged and ignored
    result := self.workspaceManager runAfterRun: wsPath
    result isError
      ifTrue: [
        Logger warn: "after_run hook failed" context: #{
          "error" => result error displayString
        }
      ]
