/// AgentRunner — full worker lifecycle for a single issue attempt.
/// Manages workspace creation, prompt rendering, codex session,
/// multi-turn loop, hook execution, and event forwarding.
///
/// Uses helper methods for prompt building, turn management, and cleanup.
Actor subclass: AgentRunner
  state: issue :: Dictionary
  state: attempt :: Integer
  state: config :: Config
  state: workspaceManager :: WorkspaceManager
  state: linearClient :: LinearClient
  state: promptTemplate :: String
  state: onEvent :: Block
  state: codexClient :: CodexClient
  state: threadId :: String
  state: turnNumber :: Integer = 0

  /// Spawns a new AgentRunner and starts the run lifecycle asynchronously.
  class run: issue :: Dictionary attempt: attempt :: Integer config: config :: Config workspaceManager: wm :: WorkspaceManager linearClient: lc :: LinearClient promptTemplate: pt :: String onEvent: callback :: Block -> AgentRunner =>
    runner := self
      spawnWith: #{
        #issue => issue,
        #attempt => attempt,
        #config => config,
        #workspaceManager => wm,
        #linearClient => lc,
        #promptTemplate => pt,
        #onEvent => callback
      }
    runner begin!
    runner

  // --- Main lifecycle ---
  terminate: _reason =>
    self.codexClient isNil ifFalse: [self.codexClient stopProcess]

  begin =>
    identifier := self.issue at: "identifier" ifAbsent: [""]
    Logger info: "agent run starting" metadata: #{"issue" => identifier}
    result := self doRun
    result isError
      ifTrue: [
        Logger error: "agent run failed" metadata: #{
          "issue_identifier" => identifier,
          "error" => result error displayString
        }
      ]
      ifFalse: [
        Logger info: "agent run completed" metadata: #{
          "issue_identifier" => identifier,
          "result" => result displayString
        }
      ]

  doRun -> Result =>
    identifier := self.issue at: "identifier" ifAbsent: [""]
    // Step 1: Create/reuse workspace
    wsResult := self.workspaceManager createForIssue: identifier
    wsResult isError ifTrue: [^wsResult]

    wsPath := wsResult unwrap at: "path"

    // Step 2: Run before_run hook
    hookResult := self.workspaceManager runBeforeRun: wsPath
    hookResult isError ifTrue: [^hookResult]

    // Step 3: Start codex session
    self.codexClient := CodexClient
      start: wsPath
      config: self.config
      onEvent: self.onEvent
    sessionResult := self.codexClient startSession
    sessionResult isError
      ifTrue: [
        self.workspaceManager runAfterRun: wsPath
        self.codexClient stopProcess
        ^sessionResult
      ]

    sessionData := sessionResult unwrap
    self.threadId := sessionData at: "threadId"

    // Step 4: Multi-turn loop
    self.turnNumber := 1
    maxTurns := self.config maxTurns
    turnLoopResult := self runTurnLoop: wsPath maxTurns: maxTurns

    // Step 5: Cleanup
    self.codexClient stopProcess
    self.workspaceManager runAfterRun: wsPath

    turnLoopResult

  // --- Prompt helpers ---

  /// Builds the prompt text for the current turn.
  buildPrompt -> Result =>
    self.turnNumber == 1 ifTrue: [
      self buildFirstTurnPrompt
    ] ifFalse: [Result ok: self buildContinuationPrompt]

  /// Renders the prompt template for the first turn.
  buildFirstTurnPrompt -> Result =>
    pr := PromptRenderer
      render: self.promptTemplate
      issue: self.issue
      attempt: self.attempt
    pr isError ifTrue: [^pr]
    Result ok: pr unwrap

  /// Returns a continuation prompt for subsequent turns.
  buildContinuationPrompt -> String =>
    "Continue working on this issue. This is turn "
      ++ self.turnNumber displayString
      ++ "."

  // --- Turn continuation check ---

  /// Returns a Result if the loop should stop, or nil to continue.
  shouldContinue: maxTurns :: Integer =>
    // Check if max turns reached
    self.turnNumber >= maxTurns ifTrue: [
      ^Result ok: #{"status" => "max_turns_reached"}
    ]

    // Re-check issue state via tracker
    refreshResult := self.linearClient fetchIssueStatesByIds: #(self.issue at: "id")
    refreshResult isError ifTrue: [^refreshResult]

    refreshed := refreshResult unwrap
    refreshed isEmpty ifTrue: [^Result ok: #{"status" => "issue_not_found"}]
    currentState := (refreshed at: 1) at: "state" ifAbsent: [nil]
    activeStates := self.config trackerActiveStates
    isActive := activeStates anySatisfy: [:s |
      s lowercase == currentState lowercase
    ]
    isActive ifFalse: [
      ^Result ok: #{
        "status" => "issue_no_longer_active",
        "state" => currentState
      }
    ]

    nil

  // --- Stream loop (runs in AgentRunner's process) ---

  /// Loops calling codexClient streamStep until turn completes or times out.
  /// Each streamStep call is short (~1s), avoiding gen_server timeout.
  streamUntilDone: turnTimeoutMs :: Integer -> Result =>
    deadline := (DateTime now asTimestamp * 1000) + turnTimeoutMs
    self streamLoop: deadline

  streamLoop: deadline :: Integer -> Result =>
    remaining := deadline - (DateTime now asTimestamp * 1000)
    remaining <= 0
      ifTrue: [
        Logger warn: "codex turn timed out"
        ^Result error: #{"kind" => "turn_timeout"}
      ]
    stepResult := self.codexClient streamStep
    // nil means no terminal event yet — keep going
    stepResult isNil ifTrue: [^self streamLoop: deadline]
    // Got a Result (ok or error) — return it
    stepResult

  // --- Turn loop ---

  /// Executes the prompt-send-stream cycle for the current turn, then recurses.
  runTurnLoop: wsPath :: String maxTurns: maxTurns :: Integer -> Result =>
    // Build prompt for this turn
    promptResult := self buildPrompt
    promptResult isError ifTrue: [^promptResult]
    promptText := promptResult unwrap

    // Start the turn
    title := (self.issue at: "identifier" ifAbsent: [""])
      ++ ": "
      ++ (self.issue at: "title" ifAbsent: [""])

    turnResult := self.codexClient
      startTurn: self.threadId
      prompt: promptText
      title: title
    turnResult isError ifTrue: [^turnResult]

    // Stream events until turn completes (step-by-step to avoid gen_server timeout)
    turnTimeoutMs := self.config codexTurnTimeoutMs
    streamResult := self streamUntilDone: turnTimeoutMs
    streamResult isError ifTrue: [^streamResult]

    // Check whether to continue
    stopResult := self shouldContinue: maxTurns
    stopResult isNil ifFalse: [^stopResult]

    // Continue with next turn
    self.turnNumber := self.turnNumber + 1
    self runTurnLoop: wsPath maxTurns: maxTurns
