/// SessionInfo — immutable value holding codex session IDs, event history,
/// and turn count for a running agent.
Value subclass: SessionInfo
  state: sessionId = nil
  state: threadId = nil
  state: turnId = nil
  state: codexPid = nil
  state: lastEvent = nil
  state: lastMessage = nil
  state: lastTimestamp = nil
  state: turnCount = 0

  incrementTurnCount => self withTurnCount: self turnCount + 1
