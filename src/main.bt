/// Main — entry point for Symphony.
/// Starts the SymphonySupervisor. Orchestrator and HttpServer self-initialize.
typed Object subclass: Main

  /// Starts the supervisor tree. Children use initialize hooks to self-start.
  class run -> Supervisor => SymphonySupervisor supervise
